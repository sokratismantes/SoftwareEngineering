<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="8dp"
    android:layout_marginBottom="8dp"
    android:background="@android:color/white"
    android:elevation="4dp"
    android:padding="16dp"
    android:clipToPadding="false"
    android:layout_marginStart="8dp"
    android:layout_marginEnd="8dp"
    android:radius="16dp">

    <TextView
        android:id="@+id/tvCode"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Κωδικός Συνταγής : #1230099"
        android:textStyle="bold"
        android:textColor="#037988"
        android:textSize="16sp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/tvExpiry"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ημερομηνία Λήξης : 31/12/2025"
        android:textColor="#888"
        android:textSize="14sp"
        app:layout_constraintTop_toBottomOf="@id/tvCode"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="2dp"/>

    <ImageView
        android:id="@+id/ivHeart"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:src="@drawable/heart_outline"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tvDoctor"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Γιατρός : Δημήτριος Αντωνίου"
        android:textColor="#444"
        android:textSize="14sp"
        app:layout_constraintTop_toBottomOf="@id/tvExpiry"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="2dp"/>

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Κατάσταση : Ενεργή"
        android:textColor="#444"
        android:textSize="14sp"
        app:layout_constraintTop_toBottomOf="@id/tvDoctor"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="2dp"/>

    <TextView
        android:id="@+id/tvCompliance"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:text="75%"
        android:textColor="#D32F2F"
        android:textStyle="bold"
        android:gravity="center"
        android:background="@drawable/compliance_circle"
        android:textSize="16sp"
        app:layout_constraintTop_toBottomOf="@id/tvStatus"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="8dp"/>

    <Button
        android:id="@+id/btnDetails"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Προβολή Λεπτομερειών"
        android:textAllCaps="false"
        android:backgroundTint="#B2E6F7"
        android:textColor="#037988"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/tvCompliance"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="12dp"/>

</androidx.constraintlayout.widget.ConstraintLayout> 