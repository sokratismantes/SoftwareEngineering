<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background_gradient"
    tools:context=".RenewPrescriptionActivity">

    <!-- Logo -->
    <ImageView
        android:id="@+id/logo"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:src="@drawable/logo"
        android:contentDescription="App Logo"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp" />

    <!-- Title -->
    <TextView
        android:id="@+id/tvRenewTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Αίτηση Ανανέωσης Συνταγής"
        android:textColor="#fff"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/logo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:textAlignment="center" />

    <!-- Prescription Code (read-only) -->
    <TextView
        android:id="@+id/tvCodeLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Κωδικός Συνταγής:"
        android:textColor="#fff"
        android:textSize="15sp"
        app:layout_constraintTop_toBottomOf="@id/tvRenewTitle"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="24dp"
        android:layout_marginStart="32dp" />

    <TextView
        android:id="@+id/tvCodeValue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="#1230099"
        android:textColor="#fff"
        android:textSize="15sp"
        app:layout_constraintTop_toBottomOf="@id/tvRenewTitle"
        app:layout_constraintStart_toEndOf="@id/tvCodeLabel"
        android:layout_marginTop="24dp"
        android:layout_marginStart="8dp" />

    <!-- Reason for Renewal -->
    <TextView
        android:id="@+id/tvReasonLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Λόγος Ανανέωσης:"
        android:textColor="#fff"
        android:textSize="15sp"
        app:layout_constraintTop_toBottomOf="@id/tvCodeLabel"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="24dp"
        android:layout_marginStart="32dp" />

    <EditText
        android:id="@+id/etReason"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:backgroundTint="#fff"
        android:textColor="#000"
        android:hint="Π.χ. Δεν επαρκεί η ποσότητα, συνεχίζονται τα συμπτώματα..."
        app:layout_constraintTop_toBottomOf="@id/tvReasonLabel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:gravity="top|start" />

    <!-- Additional Comments -->
    <TextView
        android:id="@+id/tvCommentsLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Σχόλια (προαιρετικά):"
        android:textColor="#fff"
        android:textSize="15sp"
        app:layout_constraintTop_toBottomOf="@id/etReason"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="16dp"
        android:layout_marginStart="32dp" />

    <EditText
        android:id="@+id/etComments"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:backgroundTint="#fff"
        android:textColor="#000"
        android:hint="Σχόλια για τον γιατρό..."
        app:layout_constraintTop_toBottomOf="@id/tvCommentsLabel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:gravity="top|start" />

    <!-- Submit Button -->
    <Button
        android:id="@+id/btnSubmitRenewal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Υποβολή Αίτησης"
        android:textAllCaps="false"
        android:backgroundTint="#B2E6F7"
        android:textColor="#037988"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/etComments"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="24dp" />

    <!-- Bottom Bar -->
    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:background="@android:color/transparent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/home"
            android:contentDescription="Home Icon" />

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/info"
            android:contentDescription="Info Icon"
            android:layout_marginStart="32dp"
            android:layout_marginEnd="32dp" />

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/user"
            android:contentDescription="User Icon" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout> 